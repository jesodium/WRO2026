// Copy this file to `arduino_secrets.h` and fill in your network.
// arduino_secrets.h is gitignored — real creds never get committed.
// (Arduino compiles these in; it can't read a .env at runtime, so this
//  header is the sketch-native equivalent of server/.env.)
#define SECRET_SSID "YOUR_WIFI_OR_HOTSPOT"
#define SECRET_PASS "YOUR_PASSWORD"

// Copy this file to `arduino_secrets.h` and fill in your networks.
// arduino_secrets.h is gitignored — real creds never get committed.
// (Arduino compiles these in; it can't read a .env at runtime, so this
//  header is the sketch-native equivalent of server/.env.)
// Boot scans and joins whichever network is visible; hotspot wins over school
// wins over home.
#define SECRET_SSID_HOME    "YOUR_HOME_WIFI"
#define SECRET_PASS_HOME    "YOUR_PASSWORD"
#define SECRET_SSID_SCHOOL  "YOUR_SCHOOL_WIFI"
#define SECRET_PASS_SCHOOL  "YOUR_SCHOOL_PASSWORD"
#define SECRET_SSID_HOTSPOT "YOUR_IPHONE_HOTSPOT"
#define SECRET_PASS_HOTSPOT "YOUR_HOTSPOT_PASSWORD"

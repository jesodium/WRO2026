# Bluetooth serial port (Mac). Find yours: ls /dev/cu.*
# After pairing HC-06, it usually shows as /dev/cu.HC-06-SPP
SERIAL_PORT=/dev/cu.HC-06-SPP
SERIAL_BAUD=9600

# OpenRouter (free/cheap AI models)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# How often to send AI analysis (in seconds, 0 to disable)
AI_INTERVAL=30

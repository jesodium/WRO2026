# USB serial port for wired dev/debug (Mac). Find yours: ls /dev/cu.*
# Bluetooth (R4 WiFi's BLE) is handled by the browser — no port/env needed for it.
SERIAL_PORT=/dev/cu.usbmodem1101
SERIAL_BAUD=9600

# Cerebras API (fast, generous free tier)
# Get API key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-key-here
CEREBRAS_MODEL=gpt-oss-120b

# How often to send AI analysis (in seconds, 0 to disable)
AI_INTERVAL=90

# --- TTS ---
# Primary: Deepgram Aura-2 (low-latency streaming). Free $200 credit, no card.
# Get key: https://console.deepgram.com/signup  ->  API Keys  ->  Create a New API Key
# Leave DEEPGRAM_API_KEY unset to use the free Microsoft Edge fallback instead.
DEEPGRAM_API_KEY=
# Aura-2 voice. Other male options: aura-2-draco-en, aura-2-zeus-en, aura-2-atlas-en
# Full list: https://developers.deepgram.com/docs/tts-models
DEEPGRAM_VOICE=aura-2-orion-en

# Fallback voice (Microsoft Edge neural voices, free, no key). Used when the
# Deepgram key is unset or a request fails.
# Most natural: en-US-AndrewNeural, en-US-AvaNeural, en-US-BrianNeural, en-US-EmmaNeural
TTS_VOICE=en-US-AndrewNeural

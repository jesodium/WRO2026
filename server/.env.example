# Bluetooth serial port (Mac). Find yours: ls /dev/cu.*
# After pairing HC-06, it usually shows as /dev/cu.HC-06-SPP
SERIAL_PORT=/dev/cu.HC-06-SPP
SERIAL_BAUD=9600

# Cerebras API (fast, generous free tier)
# Get API key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your-cerebras-key-here
CEREBRAS_MODEL=gpt-oss-120b

# How often to send AI analysis (in seconds, 0 to disable)
AI_INTERVAL=30
